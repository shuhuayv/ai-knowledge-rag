# 数据库配置
export DB_NAME=ai_knowledge_rag
export DB_USERNAME=ai_dev
export DB_PASSWORD=your_local_mysql_password

# Redis 配置
export REDIS_HOST=localhost
export REDIS_PORT=6379

# Qdrant 向量数据库配置
export QDRANT_URL=http://localhost:6333
export QDRANT_COLLECTION=kb_chunks

# 文件上传目录
export UPLOAD_DIR=uploads

# Chunk 切分配置
export CHUNK_SIZE=500
export CHUNK_OVERLAP=80

# Embedding 配置（双模式：mock / zhipu）
export EMBEDDING_DIMENSION=384

# 真实 Embedding（智谱 embedding-3）。取消注释并设置 Key 可启用真实模式。
# 注意：Key 仅来自环境变量，绝不写入代码/文档（此处用占位符，运行前替换为本地真实 Key）。
# export AI_EMBEDDING_PROVIDER=zhipu
# export ZHIPU_API_KEY='<your-local-api-key>'
# export AI_EMBEDDING_MODEL=embedding-3
# export AI_EMBEDDING_DIMENSIONS=1024
# export AI_EMBEDDING_BATCH_SIZE=16
# export AI_EMBEDDING_MAX_RETRIES=2
# export AI_EMBEDDING_FALLBACK_ENABLED=false